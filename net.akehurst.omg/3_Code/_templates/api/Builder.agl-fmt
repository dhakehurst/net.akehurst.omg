namespace net.akehurst.omg.mof.gen.template

import net.akehurst.omg.mof.gen.simple

format RootImport {
    MofClass -> "
        import ${TARGET_PACKAGE}.api.${qualifiedName}
        import ${TARGET_PACKAGE}.api.${qualifiedName}_Builder
    "
}

format RootBuilderFunction {
   MofClass -> {
     "
       fun ${name}(factory:${model.name}_ModelFactory, id:Any, init:${name}_Builder.()->Unit): ${validName} =
         buildObject(factory, id, ::${name}_Builder, init) {
           val rootResolver = ${model.name}_ModelResolver(\"${model.name}Model\", factory)
           rootResolver.common.${name}_resolve(it)
         }
     "
   }
}

format BuilderClassAssignment {
   MofProperty -> when {
       isSingle -> when {
         isComposite -> "_${validName}?.let{ self.${validName}Value.mutable.set(it) }"
         isReference -> "_${validName}?.let{ self.${validName}Reference.mutable.set(it) }"
         else -> 'ERROR'
       }
       else -> when {
            (false == isUnique) and (false == isOrdered) -> "_${validName}?.let{ self.${validName}.mutable.addAll(it) }"
            (true == isUnique) and (false == isOrdered) -> "_${validName}?.let{ self.${validName}.mutable.addAll(it.toSet()) }"
            (false == isUnique) and (true == isOrdered) -> "_${validName}?.let{ self.${validName}.mutable.addAll(it.toList()) }"
            (true == isUnique) and (true == isOrdered) -> "_${validName}?.let{ self.${validName}.mutable.addAll(it.toOrderedSet()) }"
            else -> "ERROR"
       }
   }
}

format BuilderClass {
   MofClass -> {
     "
        @${model.name}DslMarker
        class ${validName}_Builder(
           val factory: ${model.name}_ModelFactory,
           val id: Any
        ) : Builder<${validName}> {

            $[allCompositeAttribute sep $EOL]

            override fun build(): ${validName} = factory.${parentPackage.qualifiedName}.${validName}_construct(id).also { self ->
               $[allCompositeAttribute sep $EOL via BuilderClassAssignment]
            }
        }
     "
   }
    MofProperty -> when {
        isSingle -> when {
          type.isPrimitive -> "
            private var _${validName}: ${validTypeName}? = null
            fun ${validName}(value: ${validTypeName}) {
                _${validName} = value
            }
          "
          type.isAbstract -> "
            private var _${validName}: ${validTypeName}? = null
            fun ${validName}(init:${type.validName}_ContentBuilder.()->Unit): ${type.validName} =
                ${model.name}_ModelBuilder.buildObject(factory, identity_, ::${type.validName}_Builder, {}) { _${validName} = it }
          "
          else -> "
            private var _${validName}: ${validTypeName}? = null
            fun ${validName}(id:String, init:${type.validName}_Builder.()->Unit): ${type.validName} {
                val b = ${type.validName}_Builder(factory, id)
                b.init()
                val obj = b.build()
                _${validName} = obj
                return obj
            }
          "
        }
        else -> when {
          type.isPrimitive -> "
             private var _${validName}: Collection<${type.validName}>? = null
             fun ${validName}(value: ${validTypeName}) {
                 _${validName} = value
             }
          "
          else -> "
            private var _${validName}: Collection<${type.validName}>? = null
            fun ${validName}(init:${type.validName}_ContentBuilder.()->Unit): Collection<${type.validName}> {
                val b = ${type.validName}_ContentBuilder(factory, id)
                b.init()
                val obj = b.build()
                _${validName} = obj
                return obj
            }
          "
        }
    }
}

format ContentBuilderFunction {
   MofClass -> {
     "
        fun ${validName}(id:Any, init:${validName}_Builder.()->Unit): ${validName} =
          ${model.name}_ModelBuilder.buildObject(factory, id, ::${validName}_Builder, {}) { _content.add(it) }
     "
   }
}

format ContentBuilderClass {
   MofClass -> {
     "
        @${model.name}DslMarker
        class ${validName}_ContentBuilder(
           val factory: ${model.name}_ModelFactory,
           val id: Any
        ): Builder<Collection<${validName}>> {
            private val _content = mutableListOf<${validName}>()

            $[concreteSubclasses sep $EOL via ContentBuilderFunction]

            override fun build():Collection<${validName}> = _content
        }
     "
   }
}

format PackageImport {
    MofPackage -> "import ${TARGET_PACKAGE}.api.${qualifiedName}.*"
}

format ApiPackageBuilderFile {
    #output: 'MofPackage -> "api/$qualifiedPath/${name}_PackageBuilder.kt"'

    MofPackage -> "
        $COPYRIGHT

        // *** Generated code do NOT manually edit. ***
        package ${TARGET_PACKAGE}.api.${qualifiedName}

        import net.akehurst.kotlinx.collections.OrderedSet
        import net.akehurst.kotlinx.collections.toOrderedSet
        import net.akehurst.kotlinx.collections.CollectionExt.mutable
        import net.akehurst.kotlinx.collections.ListExt.mutable
        import net.akehurst.kotlinx.collections.SetExt.mutable
        import net.akehurst.kotlinx.collections.OrderedSetExt.mutable
        import net.akehurst.kotlinx.utils.Builder
        import net.akehurst.kotlinx.utils.ReferenceExt.mutable
        import net.akehurst.kotlinx.utils.ValueExt.mutable
        import ${TARGET_PACKAGE}.api.${model.name}DslMarker
        import ${TARGET_PACKAGE}.api.${model.name}_ModelBuilder
        import ${TARGET_PACKAGE}.api.${model.name}_ModelFactory
        $[allImport sep $EOL via PackageImport]

        $[classes sep $EOL via ContentBuilderClass]

        $[classes.filter({it -> false == it.isAbstract}) sep $EOL via BuilderClass]
    "
}

format ApiModelBuilderFile {
    #output: 'MofModel -> "api/${name}_ModelBuilder.kt"'

    MofModel -> "
        $COPYRIGHT

        // *** Generated code do NOT manually edit. ***
        package ${TARGET_PACKAGE}.api

        import net.akehurst.kotlinx.utils.Builder
        $[instanceRootList sep $EOL via RootImport]

        @DslMarker
        annotation class ${name}DslMarker

        object ${name}_ModelBuilder {

           inline fun <B : Builder<T>, T : Any> buildObject(
                factory: ${name}_ModelFactory,
                id: Any,
                noinline ctor: (${name}_ModelFactory, Any) -> B,
                init: B.() -> Unit = {},
                action: (T) -> Unit
            ): T = Builder.buildAction({ ctor.invoke(factory, id) }, init, action)

            inline fun <B : Builder<T>, T : Any> buildContent(
                factory: ${name}_ModelFactory,
                noinline ctor: (${name}_ModelFactory) -> B,
                init: B.() -> Unit = {},
                action: (T) -> Unit
            ): T = Builder.buildAction({ ctor.invoke(factory) }, init, action)

            $[instanceRootList sep $EOL via RootBuilderFunction]
        }

        ${packageList.filter({it -> false == it.isEmpty}) via ApiPackageBuilderFile}
    "


}