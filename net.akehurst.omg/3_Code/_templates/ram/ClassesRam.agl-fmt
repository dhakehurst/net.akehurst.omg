        internal data class ${validName}Ram(override val _factory: ${parentPackage.validName}_PackageFactory, override val _identity:Any) : ${validName}_NN {
            $[allNormalisedOwnedAttribute sep $EOL via PropertyGetter]

            // --- Redefined Properties ---
            $[bridgingOwnedAttributes sep $EOL via PropertyBridge]

            // --- Association owned (non-navigable) ends
            $[allNormalisedAssociationOwnedAttribute sep $EOL via PropertyGetter]

            // --- Association owned Redefined Properties ---
            $[bridgingAssociationOwnedAttributes sep $EOL via PropertyBridge]

            override fun toString(): String = \"${validName} '\${_identity}'\"
        }
    "
