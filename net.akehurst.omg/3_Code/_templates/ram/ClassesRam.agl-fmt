    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        accessor := "override val ${second.validName}: ${second.validTypeName} ${$self via BridgeImplOrgSglRefAsCol}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $accessor
        "
    }
}

format PropertyBridgeOrgColCmpAsCol {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        accessor := "override val ${second.validName}: ${second.validTypeName} ${$self via BridgeImplOrgColCmpAsCol}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $accessor
