namespace net.akehurst.omg.mof.gen.template

import net.akehurst.omg.mof.gen.simple

format UmlPropertySyntax {
    MofProperty -> {
        agg := when {
          isComposite -> 'composite '
          else -> 'reference '
        }
        cons := when {
            (false == isUnique) and (false == isOrdered) -> ''
            (true == isUnique) and (false == isOrdered) -> 'unique '
            (false == isUnique) and (true == isOrdered) -> 'ordered '
            (true == isUnique) and (true == isOrdered) -> 'ordered unique '
            else -> '{ERROR}'
        }
        redef := when {
          isRedefining -> ', redefines ' + redefinedProperty.map({it -> it.parentClass.name +'.'+ it.name}).join
          else -> ''
        }
        subs := when {
          isSubsetting -> ', subsets ' + subsettedProperty.map({it -> it.parentClass.name +'.'+ it.name}).join
          else -> ''
        }
        "$name: $typeName [$lowerBound..${when{ (-1==upperBound) -> '*' else -> upperBound}}] {$agg$cons$redef$subs}"
    }
}

format BridgeImplOrgSglCmpAsSgl {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> ->  when {
        first.isReference -> "get() = ValueImmutable(${first.validName}Reference.resolved)"
        first.isComposite -> "get() = ${first.validName}Value"
        else -> 'ERROR'
    }
}

format BridgeImplOrgSglRefAsSgl {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> when {
       first.isReference -> "get() = ${first.validName}Reference"
       first.isComposite -> "get() = ReferenceImmutable(${first.validName}._identity, ${first.validName})"
       else -> 'ERROR'
    }
}

format BridgeImplOrgColCmpAsSgl {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> ->  when {
        first.isOptional -> "get() = ${first.validName}?.let { ${second.colTypeNameLower}Of(it) } ?: ${second.colTypeNameLower}Of()"
        else -> "get() = ${second.colTypeNameLower}Of(${first.validName})"
    }
}

format BridgeImplOrgColRefAsSgl {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> when {
        first.isReference -> "get() = ${second.colTypeNameLower}Of(${first.validName}Reference)"
        first.isComposite -> "get() = ${second.colTypeNameLower}Of(ReferenceImmutable(${first.validName}._identity, ${first.validName}))"
        else -> 'ERROR'
    }
}

format BridgeImplOrgSglCmpAsCol {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> "get() = ${first.validName}.first()"
}

format BridgeImplOrgSglRefAsCol {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> "get() = ${first.validName}.first()"
}

format BridgeImplOrgColCmpAsCol {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> "get() = ${first.validName}.to${second.colTypeName}()"
}

format BridgeImplOrgColRefAsCol {
    // (redefining/as, redefined/original)
    Pair<MofProperty,MofProperty> -> when {
         first.isReference -> "get() = ${first.validName}Reference.to${second.colTypeName}()"
         first.isComposite -> "get() = ${first.validName}.to${second.colTypeName}()"
        else -> 'ERROR'
    }
}

format PropertyBridgeOrgSglCmpAsSgl {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        mutatable := "override val ${second.validName}Value: Value<${second.validTypeNameNotNullable}?> ${$self via BridgeImplOrgSglCmpAsSgl}"
        accessor := "override val ${second.validName}: ${second.validTypeName} get() = ${first.validName}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $mutatable
          $accessor
        "
    }
}

format PropertyBridgeOrgSglRefAsSgl {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        mutatable := "override val ${second.validName}Reference: Reference<Any, ${second.validTypeNameNotNullable}> ${$self via BridgeImplOrgSglRefAsSgl}"
        accessor := "override val ${second.validName}: ${second.validTypeName} get() = ${first.validName}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $mutatable
          $accessor
        "
    }
}

format PropertyBridgeOrgColCmpAsSgl {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        accessor := "override val ${second.validName}: ${second.validTypeName} ${$self via BridgeImplOrgColCmpAsSgl}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $accessor
        "
    }
}

format PropertyBridgeOrgColRefAsSgl {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        mutable := "override val ${second.validName}Reference: ${second.colTypeName}<Reference<Any,${second.type.validName}>> ${$self via BridgeImplOrgColRefAsSgl}"
        accessor := "override val ${second.validName}: ${second.validTypeName} ${$self via BridgeImplOrgColCmpAsSgl }"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $mutable
          $accessor
        "
    }
}

format PropertyBridgeOrgSglCmpAsCol {
    // (redefining/new/to, redefined/original)
    Pair<MofProperty,MofProperty> -> {
        accessor := "override val ${second.validName}: ${second.validTypeName} ${$self via BridgeImplOrgSglCmpAsCol}"
        "
          // Bridging ${second.parentClass.validName}.${second.validName} with ${first.validName}
          $accessor
        "
    }
}

